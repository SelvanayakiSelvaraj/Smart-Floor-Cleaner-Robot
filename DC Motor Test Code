int ENA = 5;
int IN1 = 6;
int IN2 = 7;

int ENB = 9;
int IN3 = 10;
int IN4 = 11;

void setup() {

  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);

  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  // Motor Speed
  analogWrite(ENA, 180);
  analogWrite(ENB, 180);
}

void loop() {

  // Move Forward

  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);

  delay(3000);

  // Stop

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);

  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  delay(2000);
}
